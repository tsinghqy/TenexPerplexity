# Supabase
NEXT_PUBLIC_SUPABASE_URL= 
NEXT_PUBLIC_SUPABASE_ANON_KEY= 
SUPABASE_SERVICE_ROLE_KEY= 

# LLM
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional web search (P3+)
# Falls back to OPENAI_API_KEY when unset. OpenRouter uses :online when web search is on.
OPENAI_WEB_SEARCH_API_KEY=
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini

# Optional defaults
DEFAULT_MODEL_ID=
DEFAULT_VISION_MODEL_ID=
# Include https:// (host-only values like my-app.vercel.app are also accepted)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
